<configuration>
  <springProfile name="dev" >
    <!-- Define the ANSI color codes -->
    <conversionRule conversionWord="clr" converterClass="org.springframework.boot.logging.logback.ColorConverter" />
    <conversionRule conversionWord="wex" converterClass="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter" />
    <conversionRule conversionWord="wEx" converterClass="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter" />

    <!-- ANSI color codes for different log levels -->
    <property name="CONSOLE_LOG_PATTERN" value="%clr(%d{HH:mm:ss.SSS}){faint} %clr([%thread]){magenta} %clr(%-5level){highlight} %clr(%logger{36}){cyan} - %msg %n" />

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        <charset>utf8</charset>
      </encoder>
    </appender>

    <!-- Set specific controller packages to INFO -->
    <logger name="tossiltossil.backend" level="DEBUG" />

    <!-- Set loggers for Spring MVC -->
    <logger name="org.springframework.web" level="INFO" />

    <!-- Root logger -->
    <root level="info">
      <appender-ref ref="STDOUT" />
    </root>
  </springProfile>

  <springProfile name="stag">
    <!-- Loki configuration for production environment -->
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
      <http>
        <url>http://loki:3100/loki/api/v1/push</url>
      </http>
      <format>
        <label>
          <pattern>app=websocket-test,env=prod,host=${HOSTNAME},level=%level,logger=%logger{36}</pattern>
        </label>
        <message>
          <pattern>%d{ISO8601} [%thread] %level %logger{36} - %msg %ex</pattern>
        </message>
      </format>
      <!-- Performance optimization settings -->
      <batchSize>100</batchSize>
      <batchTimeoutMs>1000</batchTimeoutMs>
    </appender>

    <root level="info">
      <appender-ref ref="LOKI" />
    </root>
  </springProfile>
</configuration>